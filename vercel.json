{
  "buildCommand": "node pwa/scripts/write-mapbox-config.js",
  "outputDirectory": "pwa",
  "cleanUrls": true,
  "routes": [
    { "handle": "filesystem" }
  ],
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
